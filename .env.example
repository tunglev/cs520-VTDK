# =============================================================================
# Fairlance — Environment Variables
# =============================================================================
#
# SETUP (one-time, after cloning):
#   cp .env.example .env
#   Fill in every value below — this single file is all you need.
#
# All three services (frontend, ml-service, supabase) read directly from
# this file. No per-service .env files are needed.
#
# Do NOT commit .env — it contains secrets.
# The only env file that belongs in the repo is .env.example (this file).
# =============================================================================


# ── Supabase ──────────────────────────────────────────────────────────────────
#
# Find all three values in: Supabase dashboard → Settings → API
# For local development, get them from: supabase start && supabase status

# Your Supabase project URL.
# Used by: frontend (as VITE_SUPABASE_URL), ml-service (as SUPABASE_URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable / anon key — safe to expose to the browser. Row Level Security
# ensures users can only access their own data even with this key in the open.
# Used by: frontend (as VITE_SUPABASE_ANON_KEY),
#          supabase integration tests (as SUPABASE_ANON_KEY)
SUPABASE_ANON_KEY=your-anon-key

# Service-role key — bypasses Row Level Security entirely. NEVER expose this
# to the browser or include it in any client-side bundle.
# Used by: ml-service (reads aggregate transaction data across all users to
#          compute market pricing benchmarks),
#          supabase integration tests (sets user roles after signup)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ── ML Microservice ───────────────────────────────────────────────────────────

# URL of the FastAPI ML service.
# Local development: http://localhost:8000
# Production (Railway): https://your-ml-service.up.railway.app
#
# NOTE: Edge Functions run inside Docker, so "localhost" resolves to the
# container, not your machine. Use host.docker.internal instead — Docker
# Desktop resolves this to the host on both Mac and Windows:
#   ML_SERVICE_URL=http://host.docker.internal:8000
#
# Used by: supabase Edge Function generate-pricing-report, frontend (as VITE_ML_SERVICE_URL)
ML_SERVICE_URL=http://host.docker.internal:8000

# Port the ML service binds to. Railway injects this automatically in
# production; leave it at 8000 for local development.
# Used by: ml-service only
PORT=8000

# Comma-separated list of origins allowed to call the ML service (CORS).
# The default covers local Vite dev — set this in production to your
# Vercel frontend URL so no other origin can call the service.
# Used by: ml-service only
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
